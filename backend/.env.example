# Flask 后端环境变量样例（生产前请改为真实值并妥善保管）
# 数据库连接（MySQL 8.0+）
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/zlearn_db?charset=utf8mb4

# JWT 签名密钥（生产环境必须 32+ 字符随机串）
JWT_SECRET_KEY=change-me-in-production

# Flask
FLASK_APP=app.py

# 邮件服务（可选；用于密码重置/提醒）
QQ_MAIL_TOKEN=your-qq-mail-token-here
MAIL_SERVER=smtp.qq.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-qq-email@qq.com
MAIL_PASSWORD=your-mail-auth-code
MAIL_DEFAULT_SENDER=your-qq-email@qq.com

# 前端基础 URL（用于邮件中的重置链接）
FRONTEND_URL=http://localhost:5173

# CORS 允许的源
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
